-- Location analysis

CREATE VIEW AVG_B_CS_by_C AS
SELECT Geography, AVG(Balance) AS Avg_Balance, AVG(CreditScore) AS Avg_CS
FROM Bank_Churn
GROUP BY Geography;

CREATE VIEW CoS_by_C_FAC AS
SELECT Geography,  COUNT(*) AS Costumer_Size
FROM Bank_Churn
GROUP BY Geography
ORDER BY Costumer_Size DESC; 

CREATE VIEW CoR_by_C_FAC AS
SELECT Geography,
ROUND((Costumer_Size * 100.0 / (SELECT SUM(Costumer_Size) FROM CoS_by_C_FAC)), 2) AS Churn_rate
FROM CoS_by_C_FAC
ORDER BY Churn_rate DESC;

-- Churnec Customers

CREATE VIEW CoS_by_C_FCC AS
SELECT Geography,  COUNT(*) AS Costumer_Size
FROM Churned_Costumers
GROUP BY Geography
ORDER BY Costumer_Size DESC; 

CREATE VIEW CuR_by_C_FCC AS
SELECT Geography,
ROUND((Costumer_Size * 100.0 / (SELECT SUM(Costumer_Size) FROM CoS_by_C_FCC )), 2) AS Churn_rate
FROM CoS_by_C_FCC 
ORDER BY Churn_rate DESC;
