selected_features = ['CreditScore', 'Balance', 'NumOfProducts', 'Age', 'EstimatedSalary']
bc_cluster = bc_2[selected_features]
print(bc_cluster.head())

scaler = StandardScaler()

bc_scaled = scaler.fit_transform(bc_cluster)
print(bc_scaled)

scaler = MinMaxScaler()
bc_mmscaled = scaler.fit_transform(bc_cluster)
print(bc_mmscaled)
num_clusters = 3  # Initial assumption
kmeans = KMeans(n_clusters=num_clusters, random_state=42, n_init=10)

bc_cluster['Cluster'] = kmeans.fit_predict(bc_scaled)

print(bc_cluster.head())

wcss = []
for i in range(1, 11):  # Try 1 to 10 clusters
    kmeans = KMeans(n_clusters=i, random_state=42, n_init=10)
    kmeans.fit(bc_scaled)
    wcss.append(kmeans.inertia_)  # Inertia = WCSS

plt.plot(range(1, 11), wcss, marker='o')
plt.xlabel('Number of Clusters')
plt.ylabel('WCSS (Inertia)')
plt.title('Elbow Method for Optimal Clusters')
plt.show()

